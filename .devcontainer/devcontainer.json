{
  "name": "Go CLI Development Container",
  "dockerComposeFile": "compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "customizations": {
    "vscode": {
      "extensions": [
        // ベース拡張機能
        "anthropic.claude-code",
        "donjayamanne.githistory",
        "eamodio.gitlens",
        "github.vscode-pull-request-github",
        "mhutchie.git-graph",
        "ms-ceintl.vscode-language-pack-ja",
        "seatonjiang.gitmoji-vscode",
        // Go専用拡張機能
        "golang.go",
        "tamasfe.even-better-toml",
        // Vue / フロントエンド拡張機能
        "Vue.volar",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "christian-kohler.path-intellisense",
        "streetsidesoftware.code-spell-checker"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/bin/zsh"
          }
        },
        // Go関連設定
        "go.gopath": "/home/developer/go",
        "go.goroot": "/usr/local/go",
        "go.toolsManagement.checkForUpdates": "local",
        "go.useLanguageServer": true,
        "go.formatTool": "goimports",
        "go.lintTool": "golangci-lint",
        "go.lintOnSave": "package",
        // Vue / フロントエンド設定
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[vue]": {
          "editor.defaultFormatter": "Vue.volar"
        },
        "[javascript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "eslint.validate": ["javascript", "vue"],
        "tailwindCSS.includeLanguages": {
          "vue": "html"
        }
      }
    }
  },
  "postCreateCommand": [
    "bash",
    "-c",
    "if [ -f ~/.zshrc_host ]; then echo 'source ~/.zshrc_host' >> ~/.zshrc; fi && export PATH=$HOME/.local/bin:$PATH && python3 -m pip install --user --upgrade SuperClaude && superclaude install"
  ],
  "remoteUser": "developer"
}
